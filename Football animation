<svg width="100%" height="120" viewBox="0 0 900 120" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="pitch" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#1e6b2f"/>
      <stop offset="100%" stop-color="#134d20"/>
    </linearGradient>
  </defs>

  <!-- pitch -->
  <rect x="0" y="0" width="900" height="120" fill="url(#pitch)"/>
  <g stroke="#ffffff" stroke-opacity="0.5" stroke-width="2">
    <rect x="10" y="10" width="880" height="100" fill="none"/>
    <line x1="450" y1="10" x2="450" y2="110"/>
    <circle cx="450" cy="60" r="18" fill="none"/>
    <rect x="10" y="30" width="40" height="60" fill="none"/>
    <rect x="850" y="30" width="40" height="60" fill="none"/>
  </g>

  <!-- goals -->
  <rect x="0" y="45" width="8" height="30" fill="#ffffff"/>
  <rect x="892" y="45" width="8" height="30" fill="#ffffff"/>

  <!-- ball -->
  <g>
    <circle cx="0" cy="60" r="10" fill="#ffffff" stroke="#111111" stroke-width="1.5">
      <animateMotion dur="6s" repeatCount="indefinite"
        path="M20,60 C150,20 300,100 450,60 C600,20 750,100 880,60 C750,20 600,100 450,60 C300,20 150,100 20,60 Z" />
    </circle>
  </g>

  <!-- running player marker (simple) -->
  <g fill="#ffffff">
    <circle cx="0" cy="60" r="4">
      <animateMotion dur="6s" repeatCount="indefinite"
        path="M10,70 C140,30 290,110 440,70 C590,30 740,110 870,70 C740,30 590,110 440,70 C290,30 140,110 10,70 Z" />
    </circle>
  </g>
</svg>
